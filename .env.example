# App
APP_NAME=ConstructIQ
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://constructiq:constructiq123@postgres:5432/constructiq

# Security
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# S3/Storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=constructiq-access
S3_SECRET_KEY=constructiq-secret
S3_BUCKET_NAME=constructiq-uploads
S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Frontend
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
